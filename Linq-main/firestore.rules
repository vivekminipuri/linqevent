rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user is an admin of a specific club
    function isClubAdmin(clubId) {
      return isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.adminIds;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow users to create/update their own profile
      allow write: if isAuthenticated() && request.auth.uid == userId;

      // Subcollection for certificates
      match /certificates/{certId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        // Certificates are only written by system/admins (usually via Admin SDK, but we allow it here if needed for MVP)
        allow write: if false; 
      }
    }

    // --- Clubs Collection ---
    match /clubs/{clubId} {
      // Clubs are public to view
      allow read: if true;
      // Creation of clubs - for MVP we allow authenticated users, 
      // but strictly this should be college_admin or platform_admin
      allow create: if isAuthenticated();
      // Updates only by club admins
      allow update: if isClubAdmin(clubId);
    }

    // --- Events Collection ---
    match /events/{eventId} {
      // Events are public to view (landing page)
      allow read: if true;
      
      // Creating events - only by club admins of the associated club
      allow create: if isAuthenticated() && 
        isClubAdmin(request.resource.data.clubId);
        
      // Updating events - only by club admins or the creator
      allow update: if isAuthenticated() && (
        isClubAdmin(resource.data.clubId) || 
        resource.data.createdBy == request.auth.uid
      );

      // --- Registrations Subcollection ---
      match /registrations/{regId} {
        // Users can read their own registration
        allow read: if isAuthenticated() && (
          resource.data.userId == request.auth.uid || 
          isClubAdmin(get(/databases/$(database)/documents/events/$(eventId)).data.clubId)
        );
        
        // Users can register themselves
        allow create: if isAuthenticated() && 
          request.resource.data.userId == request.auth.uid;
          
        // Updates (attendance) only by club admins
        allow update: if isAuthenticated() && 
          isClubAdmin(get(/databases/$(database)/documents/events/$(eventId)).data.clubId);
      }

      // --- Feedback Subcollection ---
      match /feedback/{fbId} {
        // Public/Authenticated read for admins to see aggregate
        allow read: if isAuthenticated() && (
          request.auth.uid == fbId || // User can read their own
          isClubAdmin(get(/databases/$(database)/documents/events/$(eventId)).data.clubId)
        );
        
        // Users can submit feedback for themselves
        allow write: if isAuthenticated() && request.auth.uid == fbId;
      }
    }

    // --- Colleges Collection ---
    match /colleges/{collegeId} {
      allow read: if true;
      allow write: if false; // Managed by platform admins via dashboard/admin
    }
  }
}
